{
  "name": "pixymon",
  "version": "1.0.0",
  "description": "트위터 기반 블록체인 뉴스 AI 에이전트",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "PIXYMON_DATA_DIR=.test-data MEMORY_DATA_PATH=.test-data/memory.json NARRATIVE_AUDIT_LOG_PATH=.test-data/narrative-observation.ndjson NARRATIVE_AUDIT_SUMMARY_PATH=.test-data/narrative-phrase-audit.json OBSERVABILITY_EVENT_LOG_PATH=.test-data/metrics-events.ndjson node --import tsx --test test/*.test.ts",
    "audit:narrative": "node scripts/narrative-audit-report.mjs",
    "samples:identity": "node --import tsx scripts/identity-samples.ts"
  },
  "keywords": [
    "ai-agent",
    "twitter",
    "blockchain",
    "crypto",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "dotenv": "^16.4.5",
    "twitter-api-v2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
